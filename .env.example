# Neo4j Configuration
# Copy this file to .env and update the values as needed

# Neo4j authentication (format: username/password)
NEO4J_AUTH=neo4j/password
NEO4J_URL=bolt://localhost:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Memory settings for Neo4j (adjust based on your machine)
# For larger graphs, increase this (e.g., 2G, 4G)
NEO4J_HEAP_SIZE=512m

# Optional: Custom ports (if 7474/7687 are taken)
# NEO4J_HTTP_PORT=7475
# NEO4J_BOLT_PORT=7688

# FalkorDB Configuration
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=movie-graph

# Default provider selection for examples/movie_industry build and search scripts.
# Supported LLM providers: openrouter, azure_openai, openai
# Supported embedder providers: openrouter, azure_openai, openai, sentence-transformer
LLM_PROVIDER=azure_openai
EMBEDDER_PROVIDER=azure_openai

# Embedding dimension used by vector indexes (must match the embedder output)
EMBEDDING_DIM=1536

# Azure OpenAI provider checks and movie smoke test
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_LLM_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBED_MODEL_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-06-01

# OpenAI provider checks
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# OpenRouter provider checks
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_EMBED_MODEL=text-embedding-3-small

# Sentence-Transformers (local, no API key)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Optional test run flags
# Set these to 1/true/yes only when you intentionally want external services.
RUN_AZURE_OPENAI_INTEGRATION_TESTS=
RUN_OPENROUTER_INTEGRATION_TESTS=
RUN_NEO4J_MOVIE_EXAMPLE_SMOKE_TESTS=
RUN_NEO4J_ENTITY_RESOLUTION_INTEGRATION_TESTS=
RUN_NEO4J_ENTITY_RESOLUTION_AI_TESTS=
RUN_FALKORDB_INTEGRATION_TESTS=
RUN_FALKORDB_MOVIE_EXAMPLE_SMOKE_TESTS=
